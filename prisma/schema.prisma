generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Service {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  duration    Int       
  price       Float
  isActive    Boolean   @default(true)
  bookings    Booking[] 
}

model Booking {
  id            Int           @id @default(autoincrement())
  customerName  String
  customerEmail String
  customerPhone String
  serviceId     Int
  service       Service       @relation(fields: [serviceId], references: [id])
  bookingDate   DateTime      
  bookingTime   String        
  status        BookingStatus @default(PENDING)
  notes         String?       
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}